# OpenAI API Key (for embeddings and image generation)
# Get your key at: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Hugging Face Token (for Hugging Face embeddings provider)
# Create token at: https://huggingface.co/settings/tokens
# Recommended scope: Read
HF_TOKEN=your_huggingface_token_here

# ElevenLabs API Key (for audio pronunciation generation)
# Get your key at: https://eu.residency.elevenlabs.io/app/developers/api-keys
# Free tier: 10,000 characters/month
# Paid tier: Starting at $5/month for 30,000 characters
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
